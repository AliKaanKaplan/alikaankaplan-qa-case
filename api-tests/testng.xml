<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Test Suite" verbose="1">
    <listeners>
        <listener class-name="framework.api.listeners.ApiTestListener"/>
    </listeners>
    <!-- Run both groups by default; use -Dgroups=positive or -Dgroups=negative from Maven to filter -->
    <test name="Pet API Tests">
        <groups>
            <run>
                <include name="positive"/>
                <include name="negative"/>
            </run>
        </groups>
        <classes>
            <class name="framework.api.tests.PetTest"/>
        </classes>
    </test>
</suite>
